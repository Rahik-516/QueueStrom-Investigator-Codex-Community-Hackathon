# ---- LLM provider ----------------------------------------------------------
# Either "openai" or "anthropic".
LLM_PROVIDER=openai

# Model id passed straight to the provider.
LLM_MODEL=gpt-4o-mini

# API key for the chosen provider.  REQUIRED.
LLM_API_KEY=sk-replace-me

# Optional extra kwargs merged into the chat call (JSON).
# Example: {"temperature": 0.0, "max_tokens": 800}
LLM_KWARGS_JSON=

# ---- Server -----------------------------------------------------------------
PORT=8000
LOG_LEVEL=INFO
DEV_RELOAD=false